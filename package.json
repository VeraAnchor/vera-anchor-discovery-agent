{
  "name": "vera-discovery-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Hedera Agent Kit MCP/x402 gateway for Vera Anchor public evidence discovery and paid proof-bundle export.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @vera-discovery/agent-api\" \"npm run dev -w @vera-discovery/web\"",
    "dev:api": "npm run dev -w @vera-discovery/agent-api",
    "dev:web": "npm run dev -w @vera-discovery/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:agent-api": "npm run test -w @vera-discovery/agent-api",
    "test:mcp-tools": "npm run test:mcp-tools -w @vera-discovery/agent-api",
    "test:mcp-stdio": "npm run test:mcp-stdio -w @vera-discovery/agent-api",
    "test:mcp": "npm run test:mcp -w @vera-discovery/agent-api",
    "test:hedera-agent": "npm run test:hedera-agent -w @vera-discovery/agent-api",
    "test:agent-integrations": "npm run test:agent-integrations -w @vera-discovery/agent-api",
    "mcp:stdio": "npm run mcp:stdio -w @vera-discovery/agent-api"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "concurrently": "^9.0.0"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}